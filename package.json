{
  "name": "launchradar-backend",
  "version": "1.0.0",
  "description": "LaunchRadar - Real-time crypto launch monitoring platform",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config src/tests/vitest.config.ts",
    "test:watch": "vitest --config src/tests/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config src/tests/vitest.config.ts",
    "test:scenario": "vitest run --config src/tests/vitest.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@fastify/helmet": "^11.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.13.2",
    "cheerio": "^1.0.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "node-fetch": "^3.3.2",
    "tesseract.js": "^5.1.1",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "nock": "^14.0.11",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  }
}
