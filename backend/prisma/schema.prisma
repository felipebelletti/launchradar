generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LaunchRecord {
  id                   String       @id @default(cuid())
  projectName          String
  ticker               String?
  launchDate           DateTime?
  launchDateRaw        String?
  launchDateConfidence Float?
  previousLaunchDate   DateTime?
  rescheduledAt        DateTime?
  launchType           String?
  chain                String?
  categories           String[]       @default([])
  primaryCategory      String?
  website              String?
  whitepaper           String?
  summary              String?
  twitterHandle        String?
  twitterFollowers     Int?
  isVerifiedAccount    Boolean      @default(false)
  confidenceScore      Float        @default(0)
  status               LaunchStatus @default(STUB)
  ruleSource           RuleSource   @default(TIER_B)
  sources              LaunchSource[]
  tweets               TweetSignal[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  launchedAt           DateTime?
}

model TweetSignal {
  id              String         @id @default(cuid())
  tweetId         String         @unique
  text            String
  imageUrls       String[]       @default([])
  imageOcrText    String?
  authorHandle    String
  authorId        String
  likes           Int            @default(0)
  retweets        Int            @default(0)
  createdAt       DateTime
  ingestedAt      DateTime       @default(now())
  launchRecordId  String?
  launchRecord    LaunchRecord?  @relation(fields: [launchRecordId], references: [id])
  ingestTiming    IngestTiming?
  timeBadge       TweetTimeBadge?
  timeBadgeDetail Int?
}

enum IngestTiming {
  FUTURE
  LIVE
  UNKNOWN
}

enum TweetTimeBadge {
  LIVE_NOW
  NEXT_HOUR
  TODAY
  THIS_WEEK
  LATER
  IN_N_DAYS
  UPCOMING
  TIME_UNKNOWN
  RESCHEDULED
  NO_DATE
}

model LaunchSource {
  id             String       @id @default(cuid())
  type           SourceType
  url            String
  rawContent     String?
  extractedData  Json?
  launchRecordId String
  launchRecord   LaunchRecord @relation(fields: [launchRecordId], references: [id])
  createdAt      DateTime     @default(now())
}

model MonitoredAccount {
  id              String    @id @default(cuid())
  twitterHandle   String    @unique
  twitterId       String?
  active          Boolean   @default(true)
  activatedAt     DateTime  @default(now())
  lastPollAt      DateTime?
  lastTweetAt     DateTime?
  launchRecordId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum LaunchStatus {
  STUB
  PARTIAL
  CONFIRMED
  VERIFIED
  LIVE
  STALE
  CANCELLED
}

enum SourceType {
  TWEET
  PROFILE
  WEBSITE
  MANUAL
  IMAGE_OCR
  ALPHAGATE
}

enum RuleSource {
  TIER_A
  TIER_B
  TIER_C
}

// ─── Auth Models ────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastActiveAt    DateTime?

  // Auth methods — all optional, at least one must exist
  walletAddress   String?   @unique
  twitterId       String?   @unique
  twitterHandle   String?
  twitterAvatar   String?
  email           String?   @unique
  passwordHash    String?

  // Profile
  displayName     String?
  avatarUrl       String?

  // Plan
  plan              Plan      @default(FREE)
  planUpdatedAt     DateTime?
  stripeCustomerId  String?   @unique
  stripeSubId       String?   @unique

  // Trial
  trialPlan         Plan?
  trialStartedAt    DateTime?
  trialExpiresAt    DateTime?
  trialFingerprint  String?
  trialUsed         Boolean   @default(false)

  // Security
  isAdmin         Boolean   @default(false)
  isSuspended     Boolean   @default(false)
  suspendedAt     DateTime?
  suspendedReason String?

  sessions        Session[]
  locationFlags   LocationFlag[]
  settings        UserSettings?
  subscription    Subscription?
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now())
  lastSeenAt   DateTime  @default(now())
  expiresAt    DateTime
  ipAddress    String
  userAgent    String
  country      String?
  city         String?
  latitude     Float?
  longitude    Float?
  fingerprint  String
  isActive     Boolean   @default(true)
}

model LocationFlag {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  createdAt    DateTime     @default(now())
  severity     FlagSeverity
  reason       String
  session1Id   String
  session2Id   String
  ipAddress    String
  country      String?
  city         String?
  reviewedAt   DateTime?
  reviewedBy   String?
  action       String?
}

model WalletNonce {
  walletAddress  String    @id
  nonce          String
  expiresAt      DateTime
}

model UserSettings {
  id            String  @id @default(cuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id])
  minFollowers  Int?
}

enum FlagSeverity {
  LOW
  MEDIUM
  HIGH
}

// ─── Plan & Billing Models ─────────────────────────────────

enum Plan {
  FREE
  SCOUT
  ALPHA
  PRO
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  INCOMPLETE
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id])
  stripeSubId        String    @unique
  stripePriceId      String
  plan               Plan
  status             SubStatus
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model AdminFlag {
  id        String   @id @default(cuid())
  type      String
  userId    String
  detail    String
  reviewed  Boolean  @default(false)
  createdAt DateTime @default(now())
}
