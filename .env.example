# Database
DATABASE_URL=postgresql://user:password@localhost:5432/launchradar

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# twitterapi.io
TWITTERAPI_KEY=your_key_here

# xAI
XAI_API_KEY=your_key_here

# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Polling / cost control
WEBHOOK_POLL_INTERVAL_SECONDS=60
DAILY_CREDIT_BUDGET=100000

# Account monitoring
ACCOUNT_MONITOR_TTL_DAYS=15
ACCOUNT_POLL_INTERVAL_MS=300000

# Allowed origin for SSE CORS — set to your frontend URL in production
FRONTEND_URL=http://localhost:5173

# AlphaGate (optional — extract from browser DevTools → Cookies)
ALPHAGATE_COOKIE_NAME=
ALPHAGATE_COOKIE_VALUE=
