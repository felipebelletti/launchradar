# Database
DATABASE_URL=postgresql://user:password@localhost:5432/launchradar

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# twitterapi.io
TWITTERAPI_KEY=your_key_here

# Anthropic
ANTHROPIC_API_KEY=your_key_here

# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Polling / cost control
WEBHOOK_POLL_INTERVAL_SECONDS=60
DAILY_CREDIT_BUDGET=100000

# Rule management
ACCOUNT_MONITOR_TTL_DAYS=15
TIER_C_POLL_INTERVAL_SECONDS=120
